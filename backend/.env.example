# ============================================
# SpeakFlow Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --------------------------------------------
# Server Configuration
# --------------------------------------------
NODE_ENV=development
PORT=3000
HOST=localhost
VERCEL_ENV=development

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# MongoDB (primary database)
DATABASE_URL=mongodb://localhost:27017/speakflow
DATABASE_PASSWORD=
DATABASE_USER=
DATABASE_NAME=speakflow
DATABASE_SSL=false

# PostgreSQL (alternative)
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=
# PG_DATABASE=speakflow

# --------------------------------------------
# Redis Configuration (for caching & sessions)
# --------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Upstash Redis (for Vercel)
# REDIS_URL=redis://default:password@xxxx.upstash.io:6379

# --------------------------------------------
# JWT Authentication
# --------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
JWT_ALGORITHM=HS256

# --------------------------------------------
# OpenAI API (AI Features)
# --------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=org-your-organization-id
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# --------------------------------------------
# Stripe Payment Integration
# --------------------------------------------
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly_id
STRIPE_PRICE_FAMILY_MONTHLY=price_family_monthly_id
STRIPE_SUCCESS_URL=https://speakflow.com/success
STRIPE_CANCEL_URL=https://speakflow.com/cancel

# --------------------------------------------
# Email Service (SendGrid)
# --------------------------------------------
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@speakflow.com
EMAIL_FROM_NAME=SpeakFlow Team
EMAIL_TEMPLATE_WELCOME=d-xxxxx
EMAIL_TEMPLATE_RESET_PASSWORD=d-xxxxx
EMAIL_TEMPLATE_SUBSCRIPTION_CONFIRM=d-xxxxx

# --------------------------------------------
# SMTP (Alternative email)
# --------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_SECURE=false

# --------------------------------------------
# AWS S3 (File Storage for uploads)
# --------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=speakflow-uploads
AWS_S3_URL=https://your-bucket.s3.amazonaws.com
CLOUD_FRONT_URL=https://your-cloudfront.cloudfront.net

# --------------------------------------------
# Google OAuth
# --------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://speakflow.com/auth/google/callback

# --------------------------------------------
# Facebook OAuth
# --------------------------------------------
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=https://speakflow.com/auth/facebook/callback

# --------------------------------------------
# Push Notifications (VAPID)
# --------------------------------------------
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:team@speakflow.com

# --------------------------------------------
# Web Push (Alternative)
# --------------------------------------------
# WEB_PUSH_PUBLIC_KEY=
# WEB_PUSH_PRIVATE_KEY=
# WEB_PUSH_SUBJECT=

# --------------------------------------------
# Analytics & Monitoring
# --------------------------------------------
ANALYTICS_ENABLED=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.2

# Google Analytics
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --------------------------------------------
# Feature Flags
# --------------------------------------------
ENABLE_AI_FEATURES=true
ENABLE_PAYMENTS=false
ENABLE_SOCIAL_LOGIN=true
ENABLE_OFFLINE_MODE=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_AUDIO_RECORDING=true
ENABLE_VIDEO_CALLS=false

# --------------------------------------------
# Rate Limiting
# --------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MESSAGE=Too many requests, please try again later.
LOGIN_RATE_LIMIT_MAX=5
API_RATE_LIMIT_MAX=100

# --------------------------------------------
# CORS Configuration
# --------------------------------------------
CORS_ORIGIN=http://localhost:3000,https://speakflow.vercel.app,https://speakflow.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_LEVEL=info
LOG_DIR=logs
LOG_MAX_FILES=14
LOG_MAX_SIZE=20m
LOG_FORMAT=combined

# --------------------------------------------
# Cache Configuration
# --------------------------------------------
CACHE_TTL=3600
CACHE_CHECK_PERIOD=600
CACHE_PREFIX=speakflow:
SESSION_TTL=86400

# --------------------------------------------
# File Upload Configuration
# --------------------------------------------
MAX_FILE_SIZE=5242880
MAX_AUDIO_SIZE=10485760
MAX_IMAGE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,audio/mpeg,audio/wav,audio/mp4
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/mp4,audio/webm
UPLOAD_DIR=uploads/
TEMP_DIR=temp/

# --------------------------------------------
# Audio Processing
# --------------------------------------------
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FORMAT=wav
VOICE_ACTIVITY_THRESHOLD=0.5
PRONUNCIATION_SENSITIVITY=0.8

# --------------------------------------------
# AI Model Configuration
# --------------------------------------------
AI_MODEL_PATH=./ai-models/pronunciation/
PRONUNCIATION_MODEL_VERSION=v2
PRONUNCIATION_CONFIDENCE_THRESHOLD=0.7
ENABLE_REAL_TIME_FEEDBACK=true
ENABLE_ACCENT_ANALYSIS=true

# --------------------------------------------
# Spaced Repetition (SRS)
# --------------------------------------------
SRS_DEFAULT_INTERVAL_DAYS=1
SRS_EASY_FACTOR=2.5
SRS_HARD_FACTOR=1.2
SRS_MAX_INTERVAL_DAYS=365
SRS_REVIEW_LIMIT=50

# --------------------------------------------
# Gamification
# --------------------------------------------
DAILY_STREAK_BONUS=50
LEVEL_UP_BASE_XP=100
XP_PER_LESSON=50
XP_PER_PERFECT_SCORE=100
MAX_DAILY_XP=500

# --------------------------------------------
# Session Management
# --------------------------------------------
SESSION_SECRET=your-session-secret-key
SESSION_MAX_AGE=86400000
SESSION_SECURE=false
SESSION_HTTP_ONLY=true

# --------------------------------------------
# Cookie Configuration
# --------------------------------------------
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax
COOKIE_MAX_AGE=86400000

# --------------------------------------------
# API Configuration
# --------------------------------------------
API_VERSION=v1
API_PREFIX=/api/v1
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3

# --------------------------------------------
# Frontend Configuration
# --------------------------------------------
FRONTEND_URL=http://localhost:3000
FRONTEND_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=https://speakflow.com
NEXT_PUBLIC_API_URL=https://api.speakflow.com

# --------------------------------------------
# PWA Configuration
# --------------------------------------------
PWA_CACHE_NAME=speakflow-v1
PWA_OFFLINE_URL=/offline.html
PWA_UPDATE_INTERVAL=3600000

# --------------------------------------------
# Security
# --------------------------------------------
BCRYPT_ROUNDS=10
JWT_ISSUER=speakflow.com
JWT_AUDIENCE=speakflow-api
CSRF_ENABLED=true
CSRF_SECRET=your-csrf-secret

# --------------------------------------------
# Backup Configuration
# --------------------------------------------
BACKUP_ENABLED=false
BACKUP_INTERVAL=86400000
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# --------------------------------------------
# Development Only
# --------------------------------------------
DEBUG_MODE=false
SHOW_ERROR_DETAILS=true
DISABLE_RATE_LIMIT=false
SEED_DATABASE_ON_START=false

# --------------------------------------------
# Testing Environment
# --------------------------------------------
TEST_DATABASE_URL=mongodb://localhost:27017/speakflow_test
TEST_REDIS_URL=redis://localhost:6379/1
TEST_PORT=3001
JEST_TIMEOUT=10000

# --------------------------------------------
# Miscellaneous
# --------------------------------------------
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,ja,ko
TIMEZONE=UTC
DATE_FORMAT=YYYY-MM-DD
