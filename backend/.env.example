# ============================================
# SPEAKFLOW - ENVIRONMENT VARIABLES EXAMPLE
# ============================================
# Copy this file to .env and update values for your environment
# Never commit .env file to version control!
# 
# Usage:
#   cp .env.example .env
#   Then edit .env with your actual values
#
# For production, use environment-specific files:
#   .env.production - Production environment
#   .env.staging    - Staging environment
#   .env.development - Development environment (default)
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================

# Node environment
# Options: development, staging, production, test
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# Server host (0.0.0.0 for all interfaces, localhost for local only)
HOST=0.0.0.0

# API base URL (for internal use)
API_URL=http://localhost:3000/api

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:8080

# WebSocket URL (for real-time features)
WS_URL=ws://localhost:3000

# Trust proxy (enable if behind reverse proxy like nginx)
TRUST_PROXY=false

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================

# Database host
DB_HOST=localhost

# Database port (default: 5432)
DB_PORT=5432

# Database name
DB_NAME=speakflow

# Database user
DB_USER=speakflow_user

# Database password (use strong password in production)
DB_PASSWORD=your_strong_password_here

# Database SSL mode
# Options: disable, require, verify-ca, verify-full
DB_SSL=disable

# Database connection pool settings
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Database timezone
DB_TIMEZONE=UTC

# Database logging (set to true for query logging)
DB_LOGGING=false

# ============================================
# REDIS CONFIGURATION (Cache & Session)
# ============================================

# Redis host
REDIS_HOST=localhost

# Redis port (default: 6379)
REDIS_PORT=6379

# Redis password (leave empty if no password)
REDIS_PASSWORD=

# Redis database index (0-15)
REDIS_DB=0

# Redis URL (alternative to individual settings)
# Format: redis://[:password@]host:port/db
REDIS_URL=redis://localhost:6379

# Redis TLS/SSL
REDIS_TLS=false

# Redis key prefix
REDIS_KEY_PREFIX=speakflow:

# Redis connection timeout (ms)
REDIS_CONNECT_TIMEOUT=10000

# Redis max retries
REDIS_MAX_RETRIES=3

# ============================================
# JWT AUTHENTICATION
# ============================================

# JWT secret key (use strong random string in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_min_32_characters_long

# JWT refresh token secret (different from access token secret)
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_characters_long

# JWT access token expiration (examples: 15m, 1h, 1d, 7d)
JWT_EXPIRES_IN=1h

# JWT refresh token expiration
JWT_REFRESH_EXPIRES_IN=7d

# JWT algorithm (HS256, RS256, etc.)
JWT_ALGORITHM=HS256

# JWT audience (optional)
JWT_AUDIENCE=speakflow-api

# JWT issuer
JWT_ISSUER=speakflow

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================

# Stripe publishable key (for frontend)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Stripe secret key (for backend)
# Never expose this key on the frontend
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Stripe webhook secret (for verifying webhook events)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Stripe price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_YEARLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_LIFETIME=price_xxxxxxxxxxxxx

# Stripe currency (USD, EUR, GBP, etc.)
STRIPE_CURRENCY=USD

# Stripe API version
STRIPE_API_VERSION=2023-10-16

# Enable Stripe webhook signature verification
STRIPE_WEBHOOK_VERIFY=true

# ============================================
# SENDGRID EMAIL CONFIGURATION
# ============================================

# SendGrid API key
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# From email address (must be verified in SendGrid)
EMAIL_FROM=noreply@speakflow.com

# From name
EMAIL_FROM_NAME=SpeakFlow Team

# Reply-to email
EMAIL_REPLY_TO=support@speakflow.com

# BCC email for monitoring (optional)
EMAIL_BCC=monitoring@speakflow.com

# Email templates
EMAIL_TEMPLATE_WELCOME=d-xxxxxxxxxxxxx
EMAIL_TEMPLATE_RESET_PASSWORD=d-xxxxxxxxxxxxx
EMAIL_TEMPLATE_WEEKLY_DIGEST=d-xxxxxxxxxxxxx
EMAIL_TEMPLATE_PREMIUM_INVOICE=d-xxxxxxxxxxxxx

# ============================================
# OPENAI CONFIGURATION (AI Features)
# ============================================

# OpenAI API key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# OpenAI organization ID (optional, for multi-org accounts)
OPENAI_ORG_ID=org-xxxxxxxxxxxxx

# OpenAI project ID (optional)
OPENAI_PROJECT_ID=proj-xxxxxxxxxxxxx

# OpenAI model for text analysis
OPENAI_MODEL=gpt-3.5-turbo

# OpenAI model for advanced analysis (more expensive)
OPENAI_MODEL_ADVANCED=gpt-4

# OpenAI Whisper model for transcription
WHISPER_MODEL=whisper-1

# OpenAI TTS model for voice synthesis
TTS_MODEL=tts-1

# OpenAI max tokens for responses
OPENAI_MAX_TOKENS=500

# OpenAI temperature (0-1, lower = more deterministic)
OPENAI_TEMPERATURE=0.7

# OpenAI request timeout (ms)
OPENAI_TIMEOUT=30000

# OpenAI max retries
OPENAI_MAX_RETRIES=3

# ============================================
# AWS S3 CONFIGURATION (File Storage)
# ============================================

# AWS region (us-east-1, eu-west-1, etc.)
AWS_REGION=us-east-1

# AWS access key ID
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxx

# AWS secret access key
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxx

# S3 bucket name for user uploads
AWS_S3_BUCKET=speakflow-uploads

# S3 bucket for backups
AWS_S3_BACKUP_BUCKET=speakflow-backups

# S3 bucket for static assets
AWS_S3_ASSETS_BUCKET=speakflow-assets

# CloudFront distribution ID (for CDN)
CLOUDFRONT_DISTRIBUTION_ID=E1XXXXXXXXXXXXX

# CloudFront URL
CLOUDFRONT_URL=https://d123.cloudfront.net

# S3 signed URL expiration (seconds)
S3_SIGNED_URL_EXPIRY=3600

# Enable server-side encryption
S3_SSE_ENABLED=true

# ============================================
# CLOUDINARY CONFIGURATION (Image/File Upload)
# ============================================

# Cloudinary cloud name
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary API key
CLOUDINARY_API_KEY=123456789012345

# Cloudinary API secret
CLOUDINARY_API_SECRET=xxxxxxxxxxxxx

# Cloudinary upload preset (for unsigned uploads)
CLOUDINARY_UPLOAD_PRESET=speakflow_uploads

# Cloudinary folder prefix
CLOUDINARY_FOLDER=speakflow

# Enable Cloudinary transformations
CLOUDINARY_TRANSFORMATIONS=true

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================

# Google OAuth client ID
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com

# Google OAuth client secret
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx

# Google OAuth redirect URI
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google OAuth scopes (comma-separated)
GOOGLE_SCOPES=email,profile

# ============================================
# GITHUB OAUTH CONFIGURATION
# ============================================

# GitHub OAuth client ID
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxx

# GitHub OAuth client secret
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxx

# GitHub OAuth redirect URI
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# GitHub OAuth scopes (comma-separated)
GITHUB_SCOPES=user:email

# ============================================
# FIREBASE CONFIGURATION (Push Notifications)
# ============================================

# Firebase project ID
# Get from: https://console.firebase.google.com
FIREBASE_PROJECT_ID=speakflow-12345

# Firebase private key (copy entire key including BEGIN/END lines)
# Format: "-----BEGIN PRIVATE KEY-----\nYourKey\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# Firebase client email
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@speakflow.iam.gserviceaccount.com

# Firebase database URL
FIREBASE_DATABASE_URL=https://speakflow-default-rtdb.firebaseio.com

# Firebase storage bucket
FIREBASE_STORAGE_BUCKET=speakflow.appspot.com

# Firebase messaging sender ID
FIREBASE_MESSAGING_SENDER_ID=123456789012

# Firebase app ID
FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# ============================================
# WEB PUSH NOTIFICATIONS
# ============================================

# VAPID public key (generate with web-push)
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BPc6sM3YxL8xZ5jK9xL2sM7cN8xV1yB4xW6cR7tY9uI0oP2

# VAPID private key
VAPID_PRIVATE_KEY=Yz8xV2bN4mQ6wE8rT0yU2iO4pA6sD8fG0hJ2kL4zX6cV8

# Contact email for push notifications (must be a mailto: URL)
VAPID_SUBJECT_EMAIL=mailto:admin@speakflow.com

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level
# Options: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Log file path (relative to project root)
LOG_FILE_PATH=logs/app.log

# Log error file path
LOG_ERROR_FILE_PATH=logs/error.log

# Log max file size (in bytes, default 10MB)
LOG_MAX_SIZE=10485760

# Log max files (retention)
LOG_MAX_FILES=5

# Log date pattern
LOG_DATE_PATTERN=YYYY-MM-DD

# Enable console logging (for development)
LOG_CONSOLE=true

# Enable JSON format for logs (for production)
LOG_JSON_FORMAT=false

# Enable log rotation
LOG_ROTATION=true

# ============================================
# RATE LIMITING CONFIGURATION
# ============================================

# Rate limit window (in minutes)
RATE_LIMIT_WINDOW=15

# Rate limit max requests per window for general endpoints
RATE_LIMIT_MAX=100

# Rate limit for authentication endpoints (login, register)
RATE_LIMIT_AUTH_MAX=10

# Rate limit for API endpoints
RATE_LIMIT_API_MAX=500

# Rate limit for WebSocket connections
RATE_LIMIT_WS_MAX=50

# Rate limit message
RATE_LIMIT_MESSAGE="Too many requests, please try again later."

# Enable rate limiting for trusted IPs
RATE_LIMIT_SKIP_TRUSTED=true

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Max file size (in bytes, default 10MB)
MAX_FILE_SIZE=10485760

# Max files per upload
MAX_FILES_PER_UPLOAD=5

# Allowed file types (comma-separated MIME types)
ALLOWED_FILE_TYPES=audio/mpeg,audio/wav,audio/mp3,audio/webm,image/jpeg,image/png

# Upload directory (relative to project root)
UPLOAD_DIR=uploads

# Temp directory for processing
TEMP_DIR=temp

# Enable file compression
FILE_COMPRESSION=true

# Enable virus scanning (requires ClamAV)
VIRUS_SCAN_ENABLED=false

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed origins (comma-separated, use * for all in development)
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,https://speakflow.com

# CORS allowed methods
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# CORS allowed headers
CORS_HEADERS=Content-Type,Authorization,X-Requested-With,X-CSRF-Token

# CORS exposed headers
CORS_EXPOSED_HEADERS=Content-Disposition,X-Total-Count

# CORS credentials (allow cookies)
CORS_CREDENTIALS=true

# CORS max age (seconds)
CORS_MAX_AGE=86400

# ============================================
# SESSION CONFIGURATION
# ============================================

# Session secret (use strong random string)
SESSION_SECRET=your_session_secret_key_min_32_characters

# Session max age (in milliseconds, default 1 day)
SESSION_MAX_AGE=86400000

# Session name (cookie name)
SESSION_NAME=speakflow.sid

# Session resave (force save even if unmodified)
SESSION_RESAVE=false

# Session save uninitialized
SESSION_SAVE_UNINITIALIZED=false

# Session cookie secure (require HTTPS)
SESSION_COOKIE_SECURE=false

# Session cookie httpOnly (prevent client-side access)
SESSION_COOKIE_HTTP_ONLY=true

# Session cookie sameSite (strict, lax, none)
SESSION_COOKIE_SAME_SITE=lax

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Helmet CSP directives (Content Security Policy)
# Format: "directive1 source1 source2; directive2 source1"
CSP_DIRECTIVES="default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.stripe.com"

# XSS protection header
XSS_PROTECTION=true

# NoSniff header (prevent MIME type sniffing)
NO_SNIFF=true

# Hide X-Powered-By header
HIDE_POWERED_BY=true

# Frame options (DENY, SAMEORIGIN, ALLOW-FROM)
FRAME_OPTIONS=SAMEORIGIN

# HSTS max age (seconds, set to 0 to disable)
HSTS_MAX_AGE=31536000

# HSTS include subdomains
HSTS_INCLUDE_SUBDOMAINS=true

# HSTS preload
HSTS_PRELOAD=false

# CSRF protection
CSRF_PROTECTION=true

# CSRF cookie name
CSRF_COOKIE_NAME=_csrf

# ============================================
# MAINTENANCE MODE
# ============================================

# Enable maintenance mode
MAINTENANCE_MODE=false

# Maintenance message (shown to users)
MAINTENANCE_MESSAGE="SpeakFlow is under maintenance. Please check back soon!"

# Maintenance allowed IPs (comma-separated, for admin access)
MAINTENANCE_ALLOWED_IPS=127.0.0.1,::1

# Maintenance start time (ISO format, optional)
MAINTENANCE_START=

# Maintenance end time (ISO format, optional)
MAINTENANCE_END=

# ============================================
# FEATURE FLAGS
# ============================================

# Core features
FEATURE_VOICE_ANALYSIS=true
FEATURE_PREMIUM=true
FEATURE_OFFLINE_MODE=true
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_SOCIAL_LOGIN=true
FEATURE_AB_TESTING=true

# Experimental features
FEATURE_VOICE_CLONING=false
FEATURE_VIDEO_CALLS=false
FEATURE_GROUP_PRACTICE=false

# Beta features
FEATURE_BETA_FEATURES=false

# ============================================
# MONITORING & ANALYTICS
# ============================================

# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/your-project/keys/
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Sentry environment
SENTRY_ENVIRONMENT=development

# Sentry traces sample rate (0-1)
SENTRY_TRACES_SAMPLE_RATE=0.2

# DataDog API key
DATADOG_API_KEY=xxxxxxxxxxxxx

# DataDog app key
DATADOG_APP_KEY=xxxxxxxxxxxxx

# DataDog service name
DATADOG_SERVICE_NAME=speakflow-api

# New Relic license key
NEW_RELIC_LICENSE_KEY=xxxxxxxxxxxxx

# New Relic app name
NEW_RELIC_APP_NAME=SpeakFlow API

# Prometheus metrics endpoint
PROMETHEUS_METRICS=true

# Prometheus metrics port
PROMETHEUS_PORT=9090

# ============================================
# BACKUP CONFIGURATION
# ============================================

# Backup schedule (cron expression)
# Examples: "0 2 * * *" (2 AM daily), "0 0 * * 0" (Sunday midnight)
BACKUP_SCHEDULE="0 2 * * *"

# Backup retention days
BACKUP_RETENTION_DAYS=30

# Backup directory (relative to project root)
BACKUP_DIR=backups

# Enable database backups
BACKUP_DATABASE=true

# Enable file backups
BACKUP_FILES=true

# Backup compression (gzip, zip)
BACKUP_COMPRESSION=gzip

# Backup notification email
BACKUP_NOTIFICATION_EMAIL=admin@speakflow.com

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Seed database on start (populates with test data)
SEED_ON_START=false

# Clear database on start (use with caution!)
CLEAR_DB_ON_START=false

# Debug mode (enables detailed error messages)
DEBUG_MODE=true

# Mock external services (stripe, sendgrid, etc.)
MOCK_SERVICES=false

# Enable hot reload (requires nodemon)
HOT_RELOAD=true

# Show SQL queries in console
SHOW_SQL_QUERIES=false

# Enable GraphQL playground (if using GraphQL)
GRAPHQL_PLAYGROUND=true

# ============================================
# TESTING CONFIGURATION
# ============================================

# Test database host
TEST_DB_HOST=localhost

# Test database port
TEST_DB_PORT=5432

# Test database name
TEST_DB_NAME=speakflow_test

# Test database user
TEST_DB_USER=test_user

# Test database password
TEST_DB_PASSWORD=test_password

# Test Redis URL
TEST_REDIS_URL=redis://localhost:6379/1

# Test JWT secret
TEST_JWT_SECRET=test_jwt_secret_key_for_testing_only

# Test API URL
TEST_API_URL=http://localhost:3001

# Test timeout (milliseconds)
TEST_TIMEOUT=30000

# Test coverage threshold
TEST_COVERAGE_THRESHOLD=80

# ============================================
# SSL/TLS CONFIGURATION (Production)
# ============================================

# SSL key path (absolute or relative to project root)
SSL_KEY_PATH=/etc/ssl/private/speakflow.key

# SSL certificate path
SSL_CERT_PATH=/etc/ssl/certs/speakflow.crt

# SSL CA bundle path (for certificate chain)
SSL_CA_PATH=/etc/ssl/certs/ca-bundle.crt

# SSL passphrase (if key is encrypted)
SSL_PASSPHRASE=

# SSL port for HTTPS server
SSL_PORT=3443

# Redirect HTTP to HTTPS
SSL_REDIRECT_HTTP=true

# ============================================
# PERFORMANCE TUNING
# ============================================

# Cluster mode (number of workers, 'max' for all CPUs, 1 for single)
CLUSTER_WORKERS=max

# Keep-alive timeout (milliseconds)
KEEP_ALIVE_TIMEOUT=5000

# Headers timeout (milliseconds)
HEADERS_TIMEOUT=60000

# Request timeout (milliseconds)
REQUEST_TIMEOUT=30000

# Response compression level (1-9)
COMPRESSION_LEVEL=6

# Enable gzip compression
GZIP_COMPRESSION=true

# Enable response caching
RESPONSE_CACHE=true

# Cache TTL (seconds)
CACHE_TTL=3600

# ============================================
# INTERNATIONALIZATION (i18n)
# ============================================

# Default language
DEFAULT_LANGUAGE=en

# Supported languages (comma-separated BCP-47 codes)
SUPPORTED_LANGUAGES=en,id,es,zh,ja,ko,fr,de,pt,ru,ar,hi

# Language detection methods (header, cookie, query)
LANGUAGE_DETECTION=header,cookie,query

# Language cookie name
LANGUAGE_COOKIE_NAME=speakflow_lang

# Language cookie max age (seconds)
LANGUAGE_COOKIE_MAX_AGE=31536000

# Translations directory (relative to project root)
TRANSLATIONS_DIR=locales

# ============================================
# API DOCUMENTATION
# ============================================

# Enable Swagger/OpenAPI documentation
SWAGGER_ENABLED=true

# Swagger UI path
SWAGGER_PATH=/api-docs

# Swagger API spec path
SWAGGER_SPEC_PATH=/api-spec.json

# Swagger title
SWAGGER_TITLE=SpeakFlow API

# Swagger description
SWAGGER_DESCRIPTION="SpeakFlow AI English Coach API Documentation"

# Swagger version
SWAGGER_VERSION=1.0.0

# ============================================
# END OF CONFIGURATION
# ============================================

# Notes:
# 1. Never commit .env files to version control
# 2. Use strong, randomly generated secrets in production
# 3. Rotate secrets regularly (every 90 days recommended)
# 4. Use different values for different environments
# 5. Keep sensitive keys in secret management systems (AWS Secrets Manager, HashiCorp Vault)
