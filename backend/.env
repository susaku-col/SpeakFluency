# ============================================
# SPEAKFLOW - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and update values for your environment
# Never commit .env file to version control!

# ============================================
# SERVER CONFIGURATION
# ============================================

# Node environment: development, staging, production
NODE_ENV=development

# Server port
PORT=3000

# Server host (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# API base URL
API_URL=http://localhost:3000/api

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================

# Database host
DB_HOST=localhost

# Database port
DB_PORT=5432

# Database name
DB_NAME=speakflow

# Database user
DB_USER=speakflow_user

# Database password
DB_PASSWORD=speakflow_password

# Database SSL (true/false)
DB_SSL=false

# Database pool settings
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ============================================
# REDIS CONFIGURATION (Cache & Session)
# ============================================

# Redis host
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis password (leave empty if no password)
REDIS_PASSWORD=

# Redis database index
REDIS_DB=0

# Redis URL (alternative to individual settings)
REDIS_URL=redis://localhost:6379

# Redis TLS (true/false)
REDIS_TLS=false

# ============================================
# JWT AUTHENTICATION
# ============================================

# JWT secret key (use strong random string in production)
JWT_SECRET=speakflow_jwt_secret_key_2024_change_this_in_production

# JWT refresh token secret
JWT_REFRESH_SECRET=speakflow_refresh_secret_key_2024_change_this_in_production

# JWT expiration (1h, 7d, 30d, etc.)
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================

# Stripe publishable key (for frontend)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe secret key (for backend)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe webhook secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Stripe price IDs
STRIPE_PRICE_MONTHLY=price_monthly_id
STRIPE_PRICE_YEARLY=price_yearly_id
STRIPE_PRICE_LIFETIME=price_lifetime_id

# ============================================
# SENDGRID EMAIL CONFIGURATION
# ============================================

# SendGrid API key
SENDGRID_API_KEY=your_sendgrid_api_key

# From email address
EMAIL_FROM=noreply@speakflow.com
EMAIL_FROM_NAME=SpeakFlow Team

# Reply-to email
EMAIL_REPLY_TO=support@speakflow.com

# BCC email for monitoring
EMAIL_BCC=monitoring@speakflow.com

# ============================================
# OPENAI CONFIGURATION (AI Features)
# ============================================

# OpenAI API key
OPENAI_API_KEY=your_openai_api_key

# OpenAI organization ID (optional)
OPENAI_ORG_ID=org_your_organization_id

# OpenAI model for pronunciation analysis
OPENAI_MODEL=gpt-3.5-turbo

# OpenAI Whisper model for transcription
WHISPER_MODEL=whisper-1

# ============================================
# AWS S3 CONFIGURATION (File Storage)
# ============================================

# AWS region
AWS_REGION=us-east-1

# AWS access key ID
AWS_ACCESS_KEY_ID=your_aws_access_key

# AWS secret access key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# S3 bucket name for uploads
AWS_S3_BUCKET=speakflow-uploads

# S3 bucket for backups
AWS_S3_BACKUP_BUCKET=speakflow-backups

# CloudFront URL for CDN
CLOUDFRONT_URL=https://d123.cloudfront.net

# ============================================
# CLOUDINARY CONFIGURATION (Image/File Upload)
# ============================================

# Cloudinary cloud name
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary API key
CLOUDINARY_API_KEY=your_api_key

# Cloudinary API secret
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================

# Google OAuth client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Google OAuth client secret
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google OAuth redirect URI
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ============================================
# GITHUB OAUTH CONFIGURATION
# ============================================

# GitHub OAuth client ID
GITHUB_CLIENT_ID=your_github_client_id

# GitHub OAuth client secret
GITHUB_CLIENT_SECRET=your_github_client_secret

# GitHub OAuth redirect URI
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# ============================================
# FIREBASE CONFIGURATION (Push Notifications)
# ============================================

# Firebase project ID
FIREBASE_PROJECT_ID=speakflow-12345

# Firebase private key
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKey\n-----END PRIVATE KEY-----\n"

# Firebase client email
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@speakflow.iam.gserviceaccount.com

# Firebase database URL
FIREBASE_DATABASE_URL=https://speakflow-default-rtdb.firebaseio.com

# ============================================
# WEB PUSH NOTIFICATIONS
# ============================================

# VAPID public key for web push
VAPID_PUBLIC_KEY=your_vapid_public_key

# VAPID private key for web push
VAPID_PRIVATE_KEY=your_vapid_private_key

# Contact email for push notifications
VAPID_SUBJECT_EMAIL=mailto:admin@speakflow.com

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Log file path
LOG_FILE_PATH=logs/app.log

# Log error file path
LOG_ERROR_FILE_PATH=logs/error.log

# Log max file size (in bytes)
LOG_MAX_SIZE=10485760

# Log max files (retention)
LOG_MAX_FILES=5

# ============================================
# RATE LIMITING CONFIGURATION
# ============================================

# Rate limit window (in minutes)
RATE_LIMIT_WINDOW=15

# Rate limit max requests per window
RATE_LIMIT_MAX=100

# Rate limit for authentication endpoints
RATE_LIMIT_AUTH_MAX=10

# Rate limit for API endpoints
RATE_LIMIT_API_MAX=500

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Max file size (in bytes)
MAX_FILE_SIZE=10485760

# Allowed file types
ALLOWED_FILE_TYPES=audio/mpeg,audio/wav,audio/mp3,audio/webm

# Upload directory
UPLOAD_DIR=uploads

# Temp directory
TEMP_DIR=temp

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,https://speakflow.com

# CORS allowed methods
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# CORS allowed headers
CORS_HEADERS=Content-Type,Authorization,X-Requested-With

# CORS credentials
CORS_CREDENTIALS=true

# ============================================
# SESSION CONFIGURATION
# ============================================

# Session secret
SESSION_SECRET=speakflow_session_secret_key_2024

# Session max age (in milliseconds)
SESSION_MAX_AGE=86400000

# Session name
SESSION_NAME=speakflow.sid

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Helmet CSP directives (comma-separated)
CSP_DIRECTIVES="default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com; style-src 'self' 'unsafe-inline';"

# XSS protection
XSS_PROTECTION=true

# NoSniff
NO_SNIFF=true

# Hide powered by
HIDE_POWERED_BY=true

# ============================================
# MAINTENANCE MODE
# ============================================

# Maintenance mode (true/false)
MAINTENANCE_MODE=false

# Maintenance message
MAINTENANCE_MESSAGE="SpeakFlow is under maintenance. Please check back soon!"

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable features
FEATURE_VOICE_ANALYSIS=true
FEATURE_PREMIUM=true
FEATURE_OFFLINE_MODE=true
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_SOCIAL_LOGIN=true
FEATURE_AB_TESTING=true

# ============================================
# MONITORING & ANALYTICS
# ============================================

# Sentry DSN for error tracking
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# DataDog API key
DATADOG_API_KEY=your_datadog_api_key

# New Relic license key
NEW_RELIC_LICENSE_KEY=your_newrelic_license_key

# ============================================
# BACKUP CONFIGURATION
# ============================================

# Backup schedule (cron expression)
BACKUP_SCHEDULE="0 2 * * *"

# Backup retention days
BACKUP_RETENTION_DAYS=30

# Backup directory
BACKUP_DIR=backups

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Seed database on start
SEED_ON_START=false

# Clear database on start (use with caution!)
CLEAR_DB_ON_START=false

# Debug mode
DEBUG_MODE=true

# Mock external services
MOCK_SERVICES=false

# ============================================
# TESTING CONFIGURATION
# ============================================

# Test database
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=speakflow_test
TEST_DB_USER=test_user
TEST_DB_PASSWORD=test_password

# Test Redis
TEST_REDIS_URL=redis://localhost:6379/1

# Test JWT secret
TEST_JWT_SECRET=test_jwt_secret_key

# ============================================
# SSL/TLS CONFIGURATION (Production)
# ============================================

# SSL key path
SSL_KEY_PATH=/etc/ssl/private/speakflow.key

# SSL certificate path
SSL_CERT_PATH=/etc/ssl/certs/speakflow.crt

# SSL CA bundle path
SSL_CA_PATH=/etc/ssl/certs/ca-bundle.crt

# ============================================
# PERFORMANCE TUNING
# ============================================

# Cluster mode (number of workers, 'max' for all CPUs)
CLUSTER_WORKERS=max

# Keep-alive timeout
KEEP_ALIVE_TIMEOUT=5000

# Headers timeout
HEADERS_TIMEOUT=60000

# Request timeout
REQUEST_TIMEOUT=30000

# ============================================
# INTERNATIONALIZATION
# ============================================

# Default language
DEFAULT_LANGUAGE=en

# Supported languages (comma-separated)
SUPPORTED_LANGUAGES=en,id,es,zh,ja

# ============================================
# END OF CONFIGURATION
# ============================================
