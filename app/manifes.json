  "shortcuts": [
    {
      "name": "Start Practice",
      "short_name": "Practice",
      "description": "Start a new speaking practice session",
      "url": "/?action=practice",
      "icons": [
        {
          "src": "/images/icons/shortcut-practice.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "My Progress",
      "short_name": "Progress",
      "description": "View your learning statistics",
      "url": "/?action=progress",
      "icons": [
        {
          "src": "/images/icons/shortcut-progress.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Daily Challenge",
      "short_name": "Challenge",
      "description": "Complete today's speaking challenge",
      "url": "/?action=challenge",
      "icons": [
        {
          "src": "/images/icons/shortcut-challenge.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Upgrade Premium",
      "short_name": "Upgrade",
      "description": "Unlock unlimited practice",
      "url": "/?action=upgrade",
      "icons": [
        {
          "src": "/images/icons/shortcut-premium.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.speakflow.app",
      "id": "com.speakflow.app"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/speakflow/id1234567890"
    }
  ],
  "prefer_related_applications": false,
  "display_override": ["window-controls-overlay", "standalone"],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/?action=note"
  },
  "launch_handler": {
    "route_to": "existing-client",
    "navigate_existing_client": "always"
  }
}
