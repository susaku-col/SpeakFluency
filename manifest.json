  "shortcuts": [
    {
      "name": "Start Practice",
      "short_name": "Practice",
      "description": "Start a speaking practice session",
      "url": "/practice",
      "icons": [
        {
          "src": "/public/images/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "My Progress",
      "short_name": "Progress",
      "description": "View your learning statistics",
      "url": "/progress",
      "icons": [
        {
          "src": "/public/images/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Leaderboard",
      "short_name": "Leaderboard",
      "description": "Check rankings and compete",
      "url": "/leaderboard",
      "icons": [
        {
          "src": "/public/images/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Settings",
      "short_name": "Settings",
      "description": "App preferences",
      "url": "/settings",
      "icons": [
        {
          "src": "/public/images/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.speakflow.app",
      "id": "com.speakflow.app"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/speakflow/id1234567890"
    }
  ],
  
  "prefer_related_applications": false,
  
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  
  "edge_side_panel": {
    "preferred_width": 400
  },
  
  "handle_links": "preferred",
  
  "note_taking": {
    "new_note_url": "/notes/new"
  },
  
  "protocol_handlers": [
    {
      "protocol": "web+speakflow",
      "url": "/share?title=%s"
    }
  ],
  
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "audio/*": [".mp3", ".wav", ".m4a"],
        "text/plain": [".txt"]
      }
    }
  ]
}
