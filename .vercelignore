# ============================================
# SpeakFlow .vercelignore
# File dan folder yang akan DIEXCLUDE dari deployment
# ============================================

# -------------------------------
# AI Models (Terlalu besar untuk Vercel)
# -------------------------------
ai-models/
**/*.pth
**/*.h5
**/*.pb
**/*.onnx
**/*.bin
**/*.model
**/*.weights
**/*.caffemodel
**/*.prototxt
**/*.onnx
**/*.tflite
**/*.keras
**/*.hdf5
**/model_v*.pth
**/fine-tuning/*.json
**/training_data.json
**/validation_data.json
**/metrics_log.csv

# -------------------------------
# Documentation Files
# -------------------------------
docs/
**/*.md
!README.md
!CODE_OF_CONDUCT.md
!CONTRIBUTING.md
**/*.pdf
**/*.doc
**/*.docx
**/API.md
**/DEPLOYMENT.md
**/USER_GUIDE.md
**/CHANGELOG.md

# -------------------------------
# Test Files
# -------------------------------
tests/
**/__tests__/
**/*.test.js
**/*.spec.js
**/*.test.ts
**/*.spec.ts
**/jest.config.js
**/jest.setup.js
coverage/
.nyc_output/
**/*.test.js.map
**/*.spec.js.map

